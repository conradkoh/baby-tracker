{
  "name": "@workspace/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clean": "pnpm store prune && pnpm install --network-timeout 100000 && pnpm expo start --ios -c",
    "dev": "BRANCH=dev expo start",
    "android": "expo run:android",
    "ios": "pnpm dev --ios",
    "web": "pnpm dev --web",
    "build": "eas build --platform all",
    "build:ios": "eas build --platform ios",
    "build:local:ios": "expo run:ios",
    "build:preview:ios": "eas build --platform ios --profile preview",
    "build:development:ios": "eas build --platform ios --profile development",
    "build:development:ios-simulator": "eas build --profile development-simulator --platform ios",
    "build:production:ios": "eas build --platform ios --profile production",
    "update:preview": "eas update --branch preview",
    "update:production": "eas update --branch production",
    "device:add": "eas device:create",
    "submit:ios": "eas submit -p ios",
    "doc": "npx expo-doctor",
    "sysreset": "pnpm store prune && lsof -t -i :8081 | xargs kill",
    "test": "jest"
  },
  "workspaces": {
    "nohoist": [
      "**"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-picker/picker": "2.11.4",
    "@shopify/flash-list": "2.0.2",
    "@workspace/backend": "workspace:*",
    "@workspace/domain": "workspace:*",
    "convex": "^1.9.1",
    "expo": "~55.0.24",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-device": "~55.0.17",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-status-bar": "~55.0.6",
    "expo-updates": "~55.0.22",
    "lodash": "^4.17.21",
    "luxon": "^3.4.4",
    "nativewind": "^2.0.11",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-vector-icons": "^10.0.3",
    "react-use": "^17.5.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.0",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.0.0",
    "@types/react": "~19.2.2",
    "@types/react-native-vector-icons": "^6.4.18",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.17",
    "tailwindcss": "3.3.2",
    "typescript": "^5.3.3"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|nativewind)"
    ],
    "setupFiles": ["./jest.setup.js"],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/__mocks__/"
    ],
    "moduleNameMapper": {
      "@workspace/backend/(.*)": "<rootDir>/__tests__/__mocks__/@workspace/backend/$1",
      "@workspace/domain/(.*)": "<rootDir>/__tests__/__mocks__/@workspace/domain/$1"
    }
  }
}
