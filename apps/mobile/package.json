{
  "name": "@workspace/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clean": "pnpm cache clean && pnpm install && pnpm expo start --ios -c",
    "dev": "BRANCH=dev expo start --ios",
    "android": "expo run:android",
    "ios": "pnpm dev --ios",
    "web": "pnpm dev --web",
    "build": "eas build --platform all",
    "build:ios": "eas build --platform ios",
    "build:local:ios": "expo run:ios",
    "build:preview:ios": "eas build --platform ios --profile preview",
    "build:development:ios": "eas build --platform ios --profile development",
    "build:development:ios-simulator": "eas build --profile development-simulator --platform ios",
    "build:production:ios": "eas build --platform ios --profile production",
    "update:preview": "eas update --branch preview",
    "update:production": "eas update --branch production",
    "device:add": "eas device:create",
    "submit:ios": "eas submit -p ios",
    "doc": "npx expo-doctor",
    "sysreset": "lsof -t -i :8081 | xargs kill"
  },
  "workspaces": {
    "nohoist": [
      "**"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.24.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-picker/picker": "2.11.4",
    "@shopify/flash-list": "1.8.3",
    "@workspace/backend": "workspace:*",
    "@workspace/domain": "workspace:*",
    "convex": "^1.38.0",
    "expo": "~52.0.0",
    "expo-clipboard": "~7.1.0",
    "expo-constants": "~17.0.0",
    "expo-crypto": "~14.0.0",
    "expo-device": "~7.0.0",
    "expo-linking": "~7.0.3",
    "expo-router": "~4.0.14",
    "expo-status-bar": "~2.0.0",
    "expo-updates": "~0.26.0",
    "lodash": "^4.18.0",
    "luxon": "^3.4.4",
    "nativewind": "^2.0.11",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-vector-icons": "^10.3.0",
    "react-use": "^17.6.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.0",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.0.0",
    "@types/react": "~18.3.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "jest": "^29.7.0",
    "tailwindcss": "3.3.2",
    "typescript": "^5.3.3"
  },
  "private": true
}
